<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Вривайся у Третю Штурмову</title>
    <!-- Tailwind CSS для стильного дизайну -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Шрифти Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap" rel="stylesheet">
    <!-- Lucide Icons для іконок -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        body {
            font-family: 'Montserrat', sans-serif;
            background-color: #0c0c0c;
        }
        .orange-glow {
            text-shadow: 0 0 20px rgba(255, 110, 0, 0.6);
        }
        .btn-glow:hover {
            box-shadow: 0 0 25px rgba(255, 110, 0, 0.8);
        }
    </style>
</head>
<body class="text-gray-100 selection:bg-orange-600 selection:text-white">

    <!-- НАВІГАЦІЯ -->
    <header class="fixed top-0 left-0 w-full z-50 bg-black/80 backdrop-blur-md border-b border-orange-600/20">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-3">
                <!-- Стилізований логотип (шеврон/тризуб) -->
                <span class="text-orange-500 font-black text-2xl tracking-wider">III</span>
                <span class="font-bold text-sm tracking-widest text-white hidden sm:inline">3-ТЯ ШТУРМОВА</span>
            </div>
            <nav class="flex gap-6 text-sm font-semibold tracking-wider">
                <a href="#about" class="hover:text-orange-500 transition">ПРО БРИГАДУ</a>
                <a href="#vacancies" class="hover:text-orange-500 transition">ВАКАНСІЇ</a>
                <a href="#apply" class="bg-orange-600 hover:bg-orange-500 text-black px-4 py-2 rounded font-bold transition btn-glow">ПОДАТИ ЗАЯВКУ</a>
            </nav>
        </div>
    </header>

    <!-- ГОЛОВНИЙ ЕКРАН (HERO SECTION) -->
    <section class="relative min-h-screen flex flex-col justify-center items-center px-6 pt-20 overflow-hidden bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-zinc-900 via-black to-black">
        <!-- Фонова сітка для стилю -->
        <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
        
        <div class="relative z-10 text-center max-w-4xl mx-auto space-y-6">
            <span class="text-orange-500 font-bold tracking-widest text-sm uppercase">Офіційний рекрутинг</span>
            <h1 class="text-5xl md:text-8xl font-black tracking-tighter text-white uppercase leading-none">
                ВРИВАЙСЯ У <br>
                <span class="text-orange-500 orange-glow">ТРЕТЮ ШТУРМОВУ</span>
            </h1>
            <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto font-light">
                Шлях воїна починається тут. Стань частиною легендарної бригади. Досвідчені інструктори, топове спорядження та справжнє братерство.
            </p>
            <div class="flex flex-col sm:flex-row justify-center gap-4 pt-6">
                <a href="#apply" class="bg-orange-600 hover:bg-orange-500 text-black text-lg font-black px-8 py-4 rounded uppercase tracking-wider transition btn-glow flex items-center justify-center gap-2">
                    <i data-lucide="shield-check" class="w-5 h-5"></i> Заповнити анкету
                </a>
                <a href="#vacancies" class="border border-orange-600/50 hover:bg-orange-600/10 text-white text-lg font-bold px-8 py-4 rounded uppercase tracking-wider transition flex items-center justify-center gap-2">
                    Вакансії
                </a>
            </div>
        </div>
    </section>

    <!-- ПРО БРИГАДУ -->
    <section id="about" class="py-24 px-6 max-w-6xl mx-auto border-t border-zinc-800">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="p-8 bg-zinc-950 border border-zinc-800 rounded-lg space-y-4">
                <div class="text-orange-500"><i data-lucide="users" class="w-10 h-10"></i></div>
                <h3 class="text-xl font-bold uppercase">Братерство</h3>
                <p class="text-gray-400 text-sm leading-relaxed">Один за всіх і всі за одного. Ти отримаєш підтримку побратимів, на яких можна покластися у будь-якій ситуації.</p>
            </div>
            <div class="p-8 bg-zinc-950 border border-zinc-800 rounded-lg space-y-4">
                <div class="text-orange-500"><i data-lucide="award" class="w-10 h-10"></i></div>
                <h3 class="text-xl font-bold uppercase">Професіоналізм</h3>
                <p class="text-gray-400 text-sm leading-relaxed">Навчання за стандартами НАТО. Наші інструктори пройшли найважчі бої та передадуть тобі реальний досвід.</p>
            </div>
            <div class="p-8 bg-zinc-950 border border-zinc-800 rounded-lg space-y-4">
                <div class="text-orange-500"><i data-lucide="zap" class="w-10 h-10"></i></div>
                <h3 class="text-xl font-bold uppercase">Технологічність</h3>
                <p class="text-gray-400 text-sm leading-relaxed">Сучасна зброя, бронетехніка, безпілотники та засоби зв'язку. Ми воюємо розумом та технологіями.</p>
            </div>
        </div>
    </section>

    <!-- ФОРМА ПОДАННЯ ЗАЯВКИ -->
    <section id="apply" class="py-24 px-6 bg-zinc-950 border-t border-zinc-800 relative">
        <div class="max-w-3xl mx-auto">
            <div class="text-center space-y-4 mb-12">
                <h2 class="text-4xl font-black text-orange-500 uppercase tracking-tight">ПОДАТИ ЗАЯВКУ</h2>
                <p class="text-gray-400">Заповни форму, і наш рекрутинговий центр зв'яжеться з тобою найближчим часом. Конфіденційність гарантовано.</p>
            </div>

            <!-- ФОРМА (Інтегрується з Telegram за інструкцією нижче) -->
            <form id="recruitmentForm" class="space-y-6 bg-black p-8 rounded-lg border border-orange-600/30">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Прізвище та Ім'я</label>
                        <input type="text" id="name" required class="w-full bg-zinc-900 border border-zinc-800 focus:border-orange-500 focus:outline-none p-3 rounded text-white" placeholder="Іванов Іван">
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Телефон (Telegram / Signal)</label>
                        <input type="tel" id="phone" required class="w-full bg-zinc-900 border border-zinc-800 focus:border-orange-500 focus:outline-none p-3 rounded text-white" placeholder="+380 99 123 45 67">
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Вік</label>
                        <input type="number" id="age" required min="18" max="60" class="w-full bg-zinc-900 border border-zinc-800 focus:border-orange-500 focus:outline-none p-3 rounded text-white" placeholder="25">
                    </div>
                    <div>
                        <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Бажаний напрямок (Вакансія)</label>
                        <select id="vacancy" class="w-full bg-zinc-900 border border-zinc-800 focus:border-orange-500 focus:outline-none p-3 rounded text-white appearance-none">
                            <option value="Штурмовик">Штурмовик</option>
                            <option value="Оператор БПЛА">Оператор БПЛА</option>
                            <option value="Медик">Бойовий медик</option>
                            <option value="Водій / Механік">Водій / Механік-водій</option>
                            <option value="Тилове забезпечення">Тилове забезпечення (SVO / Склади)</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold uppercase tracking-wider text-gray-400 mb-2">Військовий досвід чи цивільна спеціальність</label>
                    <textarea id="experience" rows="3" class="w-full bg-zinc-900 border border-zinc-800 focus:border-orange-500 focus:outline-none p-3 rounded text-white" placeholder="Наприклад: досвід служби в ЗСУ, водій категорії C, або програміст..."></textarea>
                </div>

                <button type="submit" class="w-full bg-orange-600 hover:bg-orange-500 text-black font-black py-4 rounded uppercase tracking-wider transition btn-glow">
                    Відправити анкету
                </button>
                <div id="formStatus" class="text-center mt-4 hidden font-bold"></div>
            </form>
        </div>
    </section>

    <!-- ФУТЕР -->
    <footer class="bg-black py-8 text-center text-xs text-gray-600 border-t border-zinc-900">
        <p>© 2026 Рекрутинговий сайт прихильників 3-ї ОШБр. Неофіційний патріотичний ресурс.</p>
    </footer>

    <!-- Ініціалізація іконок та логіка відправки форми -->
    <script>
        lucide.createIcons();

        // Налаштування Telegram-бота (деталі у Кроці 2)
        const TELEGRAM_BOT_TOKEN = 'ТВІЙ_BOT_TOKEN'; // Сюди вставиш токен від BotFather
        const TELEGRAM_CHAT_ID = 'ТВІЙ_CHAT_ID';     // Сюди свій ID або ID групи

        document.getElementById('recruitmentForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            
            const name = document.getElementById('name').value;
            const phone = document.getElementById('phone').value;
            const age = document.getElementById('age').value;
            const vacancy = document.getElementById('vacancy').value;
            const experience = document.getElementById('experience').value;
            const statusDiv = document.getElementById('formStatus');

            // Текст повідомлення, який прийде в Telegram
            const text = `🎯 *Нова заявка!*\n\n` +
                         `👤 *Ім'я:* ${name}\n` +
                         `📞 *Телефон:* ${phone}\n` +
                         `🎂 *Вік:* ${age}\n` +
                         `⚔️ *Напрямок:* ${vacancy}\n` +
                         `📝 *Досвід:* ${experience}`;

            statusDiv.classList.remove('hidden', 'text-green-500', 'text-red-500');
            statusDiv.textContent = 'Відправка...';
            statusDiv.classList.add('text-orange-500');

            try {
                const response = await fetch(`https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        chat_id: TELEGRAM_CHAT_ID,
                        text: text,
                        parse_mode: 'Markdown'
                    })
                });

                if (response.ok) {
                    statusDiv.textContent = '✅ Заявка успішно надіслана! Скоро з вами зв\'яжуться.';
                    statusDiv.classList.replace('text-orange-500', 'text-green-500');
                    document.getElementById('recruitmentForm').reset();
                } else {
                    throw new Error('Помилка сервера');
                }
            } catch (error) {
                statusDiv.textContent = '❌ Помилка відправки. Спробуйте пізніше або зв\'яжіться напряму.';
                statusDiv.classList.replace('text-orange-500', 'text-red-500');
            }
        });
    </script>
</body>
</html>
